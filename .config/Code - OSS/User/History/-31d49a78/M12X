CXX = g++
CXXFLAGS = -std=c++17 -Wall -Wextra -O2
TARGET = StudentManagementSystem
SOURCES = main.cpp
HEADERS = date.h student.h node.h container.h linkedlist.h studentmanager.h menu.h
OBJECTS = $(SOURCES:.cpp=.o)

all: $(TARGET)

$(TARGET): $(OBJECTS)
	$(CXX) $(CXXFLAGS) -o $(TARGET) $(OBJECTS)

%.o: %.cpp $(HEADERS)
	$(CXX) $(CXXFLAGS) -c $< -o $@

clean:
	rm -f $(OBJECTS) $(TARGET)

run: $(TARGET)
	./$(TARGET)

debug: CXXFLAGS += -g -DDEBUG
debug: clean all

.PHONY: all clean run debug