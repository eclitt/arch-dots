{
  "layer": "top",
  "position": "top",
  "margin-bottom": 0,
  "spacing": 0,

  "modules-left": [
    "clock",
    "custom/cava",
    "group/hardware",
    "tray"
  ],

  "modules-center": [
    "hyprland/workspaces"
  ],

  "modules-right": [
    "hyprland/language",
    "network",
    "pulseaudio",
    "backlight",
    "power-profiles-daemon",
    "battery",
    "group/group-power"
  ],

  "clock": {
    "tooltip": false,
    "format": "{:%H:%M:%S  -  %A, %d}",
    "interval": 1
  },

  "tray": {
    "icon-size": 16,
    "spacing": 5
  },

  "custom/cava": {
    "format": "{}",
    "exec": "~/.config/scripts/waybar/waybar-cava",
    "return-type": "json"
  },

  "group/hardware": {
    "orientation": "horizontal",
    "drawer": {
      "transition-duration": 500,
      "children-class": "not-cpu",
      "transition-left-to-right": true
    },
    "modules": [
      "cpu",
      "memory",
      "custom/cpu_temp",
      "custom/gpu_temp"
    ]
  },

  "cpu": {
    "interval": 1,
    "format": "ΎΜδ  {usage:>2}%",
    "max-length": 10
  },

  "memory": {
    "interval": 30,
    "format": "ΎΔΚ {}%",
    "max-length": 10
  },

  "custom/cpu_temp": {
    "exec": "sensors | grep -A 0 'Tdie\\|Tctl' | head -1 | awk '{print $2}' | sed 's/+//;s/┬░C//'",
    "format": "ΎΜΚ {}┬░C",
    "interval": 5,
    "tooltip": false,
    "return-type": "json"
  },

  "custom/gpu_temp": {
    "exec": "sensors | grep -A 0 'edge\\|junction' | head -1 | awk '{print $2}' | sed 's/+//;s/┬░C//'",
    "format": "ΎΕδ   {}┬░C",
    "interval": 5,
    "tooltip": false,
    "return-type": "json"
  },

  "hyprland/workspaces": {
    "format": "{icon}",
    "format-icons": {
      "active": "ΎΗΤ",
      "default": "ΎΕΣ"
    }
  },

  "hyprland/language": {
    "format": "{}",
    "format-en": "us",
    "format-ru": "zov",
    "keyboard-name": "at-translated-set-2-keyboard"
  },

  "network": {
    "format-wifi": "≤░νλ",
    "format-ethernet": "≤░ΙΑ",
    "format-disconnected": "≤░νι",
    "interval": 5,
    "tooltip-format": "{essid} ({signalStrength}%)",
    "on-click": "kitty nmtui"
  },

  "pulseaudio": {
    "format": "{icon}  {volume}%",
    "format-muted": "ΎΣο ",
    "format-icons": {
      "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
    },
    "scroll-step": 4.0,
    "max-volume": 125,
    "on-click": "pavucontrol",
    "on-click-right": "bash -c 'wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle'"
  },

  "backlight": {
    "format": "{icon}  {percent}%",
    "format-icons": ["ΌΟΞ", "≤░Δε", "≤░Δδ", "≤░Δη", "≤░Δζ", "≤░Δθ", "≤░Δι"],
    "tooltip": false
  },

  "battery": {
    "interval": 2,
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15
    },
    "format": "{icon}  {capacity}%",
    "format-full": "{icon}  {capacity}%",
    "format-charging": "ΎΘο {capacity}%",
    "format-plugged": "ΎΘο {capacity}%",
    "format-alt": "{icon} {time}",
    "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
    "on-click": "pavucontrol"
  },

  "power-profiles-daemon": {
    "format": "έγκ {profile}",
    "tooltip-format": "╨θ╤Α╨╛╤Ε╨╕╨╗╤Ν ╨┐╨╕╤Γ╨░╨╜╨╕╤Π: <b>{profile}</b>",
    "tooltip": true,
    "format-icons": {
      "default": "ΎΒυ",
      "performance": "ΎΔπ",
      "balanced": "ΎΚΟ",
      "power-saver": "ΎΒυ"
    },
    "on-click": "~/.config/scripts/waybar/pdd-wofi",
    "on-click-right": "powerprofilesctl set balanced"
  },

  "group/group-power": {
    "orientation": "horizontal",
    "drawer": {
      "transition-duration": 500,
      "children-class": "not-power",
      "transition-left-to-right": true
    },
    "modules": [
      "custom/power",
      "custom/quit",
      "custom/lock",
      "custom/reboot"
    ]
  },

  "custom/quit": {
    "format": "≤░Ω╝",
    "tooltip": false,
    "on-click": "hyprctl dispatch exit"
  },

  "custom/lock": {
    "format": "≤░ΞΒ",
    "tooltip": false,
    "on-click": "hyprlock"
  },

  "custom/reboot": {
    "format": "≤░εΚ",
    "tooltip": false,
    "on-click": "reboot"
  },

  "custom/power": {
    "format": "ΎΑΣ",
    "tooltip": false,
    "on-click": "shutdown now"
  }
}