# Основные параметры стиля
background-color=#000000
text-color=#FFFFFF
border-color=#ffffff
progress-color=over #ffffff
border-size=1
border-radius=5

# Размеры и отступы
width=300
height=120
margin=10
padding=15

# Параметры текста
font=sans-serif 10
markup=true
text-alignment=center

# Поведение уведомлений
default-timeout=10000
ignore-timeout=false
group-by=app-name
sort=-time

# Разное
actions=true
history=true
max-visible=5
layer=overlay
anchor=top-right