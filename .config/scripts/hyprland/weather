#!/bin/bash

# Конфигурация
CACHE_DIR="${HOME}/.cache/weather"
CACHE_FILE="${CACHE_DIR}/weather.txt"
MAX_AGE_MINUTES=5  # Изменил на 5 минут по вашему требованию

mkdir -p "$CACHE_DIR"

# Проверка возраста файла
is_cache_valid() {
    [[ -f "$CACHE_FILE" ]] && \
    [[ $(find "$CACHE_FILE" -mmin +"$MAX_AGE_MINUTES" 2>/dev/null | wc -l) -eq 0 ]]
}

# Получение ТОЛЬКО ТЕКСТОВОЙ погоды
get_weather() {
    # Получаем чистую температуру (без иконок)
    local temp=$(curl -s --connect-timeout 5 "wttr.in/Novosibirsk?format=%t" 2>/dev/null)
    
    # Если получили что-то
    if [[ -n "$temp" ]]; then
        # Удаляем все лишние символы, оставляем только температуру
        echo "$temp" | sed 's/[^0-9+°C°F-]//g'
    else
        # Fallback значение
        echo "Error"
    fi
}

# Основная логика
if is_cache_valid; then
    # Используем кеш, если он новый
    cat "$CACHE_FILE"
else
    # Кеш старый или его нет - пытаемся получить свежие данные
    weather_data=$(get_weather)
    
    if [[ $? -eq 0 && -n "$weather_data" && "$weather_data" != "Error" ]]; then
        # Успешно получили данные с сайта
        echo "$weather_data" > "$CACHE_FILE"
        echo "$weather_data"
    else
        # Не удалось получить свежие данные - используем кеш с пометкой
        if [[ -f "$CACHE_FILE" ]]; then
            echo "[кеш] $(cat "$CACHE_FILE")"
        else
            # Нет даже кеша - используем значение по умолчанию
            echo "Error: no cahce and connect"
        fi
    fi
fi
